# Database — PostgreSQL connection string
# Local (Docker Compose): postgresql://hortensia:hortensia@localhost:5432/hortensia
# Production: your managed Postgres URL (Neon, Supabase, RDS)
DATABASE_URL="postgresql://hortensia:hortensia@localhost:5432/hortensia"

# NextAuth.js — secret for encrypting JWT tokens
# Generate a strong one with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-secret-at-least-32-chars-long"

# NextAuth.js — canonical URL of your deployment
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"

# Groq — AI-powered request improvement (free tier)
# Get your free API key at https://console.groq.com
GROQ_API_KEY="your-groq-api-key-here"
