# Database — PostgreSQL connection string
# Local (Docker Compose): postgresql://hortensia:hortensia@localhost:5432/hortensia
# Production: your managed Postgres URL (Neon, Supabase, RDS)
DATABASE_URL="postgresql://hortensia:hortensia@localhost:5432/hortensia"

# NextAuth.js — secret for encrypting JWT tokens
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="replace-with-openssl-rand-base64-32"

# NextAuth.js — canonical URL of your deployment
# Local: http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"
